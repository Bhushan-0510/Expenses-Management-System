# Example backend environment variables (do NOT commit real secrets)
# Required
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/expenses?retryWrites=true&w=majority
JWT_SECRET=change_this_to_a_long_random_string

# Optional
# CORS_ORIGIN can be a single origin (not '*') if you need credentials
CORS_ORIGIN=https://expenses-management-system-ga8g.onrender.com
CORS_ALLOW_CREDENTIALS=false

# Port (defaults to 5000 if not set)
PORT=5000
